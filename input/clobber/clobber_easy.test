{version 1.5}

[clobber]

/* 2x2  */
XO|OX
    {B win}

/* 2x3  */
XOX|OXO
	 {B loss}

/* 2x4  */
XOXO|OXOX
	 {B win}

/* 2x5  */
XOXOX|OXOXO
	 {B win}

/* 2x6  */
XOXOXO|OXOXOX
	 {B loss}

/* 2x7 */
XOXOXOX|OXOXOXO
	 {B win}

/* 2x8 */
XOXOXOXO|OXOXOXOX
	 {B win}

/* 3x3  */
XOX|OXO|XOX
    {B win, W win}

/* 3x4  */
XOXO|OXOX|XOXO
	 {B loss}

/* 3x5  */
XOXOX|OXOXO|XOXOX
	 {B win}

/* 3x6  */
XOXOXO|OXOXOX|XOXOXO
	 {B loss}

/* 3x7 */
XOXOXOX|OXOXOXO|XOXOXOX
	 {B win}

/* 3x8 */
XOXOXOXO|OXOXOXOX|XOXOXOXO
	 {B loss}

/* 4x4  */
XOXO|OXOX|XOXO|OXOX
    {B win}

/* 4x5  */
XOXOX|OXOXO|XOXOX|OXOXO
	 {B win}

/* 4x6 */
XOXOXO|OXOXOX|XOXOXO|OXOXOX
	 {B loss}

/* 5x5 */
XOXOX|OXOXO|XOXOX|OXOXO|XOXOX
    {B loss, W loss}




