/*_ Basic CGT games */

    [dyadic_rational]
5/4
{winning moves B DEC,
winning moves W None}

    [dyadic_rational]
20/4
-24/2
{winning moves B None,
winning moves W 1:INC}

    [impartial dyadic_rational]
21/8
{winning moves N INC,
winning moves B INC,
winning moves W INC}

    [impartial dyadic_rational]
12/16
-21/8
{winning moves N 0:INC 1:DEC,
winning moves B 0:INC 1:DEC,
winning moves W 0:INC 1:DEC}

    [integer_game]
5
{winning moves B INT,
winning moves W None}

    [integer_game]
-3
{winning moves B None,
winning moves W INT}

    [impartial integer_game]
7
{winning moves N INT,
winning moves B INT,
winning moves W INT}

    [impartial integer_game]
6
-7
{winning moves N 0:INT 1:INT,
winning moves B 0:INT 1:INT,
winning moves W 0:INT 1:INT}

    [nimber]
5
{winning moves N *0,
winning moves B *0,
winning moves W *0}

    [nimber]
3 5
{winning moves N 1:*3,
winning moves B 1:*3,
winning moves W 1:*3}

    [impartial nimber]
5
{winning moves N *0,
winning moves B *0,
winning moves W *0}

    [impartial nimber]
3 5
{winning moves N 1:*3,
winning moves B 1:*3,
winning moves W 1:*3}

    [switch_game]
(3/4, -4)
{winning moves B SWITCH_L,
winning moves W SWITCH_R}

    [switch_game]
(1/2, -1/2)
(-6, 5)
{winning moves B 0:SWITCH_L,
winning moves W 0:SWITCH_R}

    [impartial switch_game]
(-6, 7)
{winning moves N SWITCH_L,
winning moves B SWITCH_L,
winning moves W SWITCH_L}

    [impartial switch_game]
(1/2, 4)
(-2, 3)
{winning moves N 0:SWITCH_L 1:SWITCH_R,
winning moves B 0:SWITCH_L 1:SWITCH_R,
winning moves W 0:SWITCH_L 1:SWITCH_R}

    [up_star]
(* 3)
{winning moves B 0,
winning moves W None}

    [up_star]
(6 *)
-3
{winning moves B 1:-2*,
winning moves W None}

    [impartial up_star]
(*)
{winning moves N 0,
winning moves B 0,
winning moves W 0}

    [impartial up_star]
4
-5
{winning moves N 0:3* 1:-4*,
winning moves B 0:3* 1:-4*,
winning moves W 0:3* 1:-4*}

    [kayles]
6
{winning moves N 1-1-4 2-2-2,
winning moves B 1-1-4 2-2-2,
winning moves W 1-1-4 2-2-2}

    [kayles]
3
7
{winning moves N 0:1-0-2 1:1-0-6 1:1-2-4,
winning moves B 0:1-0-2 1:1-0-6 1:1-2-4,
winning moves W 0:1-0-2 1:1-0-6 1:1-2-4}

    [impartial kayles]
6
{winning moves N 1-1-4 2-2-2,
winning moves B 1-1-4 2-2-2,
winning moves W 1-1-4 2-2-2}

    [impartial kayles]
3
7
{winning moves N 0:1-0-2 1:1-0-6 1:1-2-4,
winning moves B 0:1-0-2 1:1-0-6 1:1-2-4,
winning moves W 0:1-0-2 1:1-0-6 1:1-2-4}
